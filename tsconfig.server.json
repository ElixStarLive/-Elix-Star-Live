{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server",
    "rootDir": "server",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": false,
    "esModuleInterop": true,
    "declaration": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules"]
}
