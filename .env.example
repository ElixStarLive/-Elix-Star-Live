# ═══════════════════════════════════════════════════════════════════
# ELIX STAR LIVE — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# In production (Coolify), set these as environment variables directly.
# ═══════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# ── Database (Neon PostgreSQL) — REQUIRED ─────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
PG_POOL_MAX=20
PG_POOL_MIN=2

# ── Auth — REQUIRED ──────────────────────────────────────────────
# Must be at least 256-bit random hex (64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Shared State (Valkey/Redis) — REQUIRED for production ────────
# In Coolify: add a Valkey service on the same private network
# Format: redis://valkey-service-name:6379
VALKEY_URL=redis://valkey.internal:6379
# Alternative key name (either works):
# REDIS_URL=redis://valkey.internal:6379

# ── Bunny Storage (Avatars/Images) — REQUIRED ────────────────────
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_API_KEY=your-storage-api-key
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_STORAGE_REGION=de

# ── Bunny Video (Streaming) — REQUIRED for video uploads ─────────
BUNNY_LIBRARY_ID=your-library-id
BUNNY_LIBRARY_API_KEY=your-library-api-key
BUNNY_CDN_HOSTNAME=your-cdn.b-cdn.net

# ── LiveKit (Live Streaming) — REQUIRED ──────────────────────────
LIVEKIT_URL=wss://your-livekit.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── Stripe (Shop physical goods ONLY) — REQUIRED ─────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Frontend Configuration (built into client bundle) ─────────────
VITE_API_URL=https://your-domain.com
VITE_WS_URL=wss://your-domain.com
VITE_LIVEKIT_URL=wss://your-livekit.livekit.cloud
VITE_BUNNY_CDN_HOSTNAME=your-cdn.b-cdn.net
VITE_BUNNY_STORAGE_ZONE=your-storage-zone
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
VITE_APP_NAME="Elix Star Live"
VITE_CDN_URL=https://your-cdn.b-cdn.net
CLIENT_URL=https://your-domain.com

# ── Optional ──────────────────────────────────────────────────────
# AI moderation (OpenAI) — optional, moderation will skip if not set
OPENAI_API_KEY=

# Push notifications — optional, device tokens stored but not sent without these
# FCM_SERVER_KEY=
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY_PATH=
