# ═══════════════════════════════════════════════════════════════════
# ELIX STAR LIVE — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# In production (Coolify), set these as environment variables directly.
# ═══════════════════════════════════════════════════════════════════

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
# Number of worker processes (defaults to CPU count, max 8)
# WEB_CONCURRENCY=4

# ── Database (Neon PostgreSQL) — REQUIRED ─────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
PG_POOL_MAX=50
PG_POOL_MIN=5
# PG_SSL_REJECT_UNAUTHORIZED defaults to verifying TLS in production.
# Set to false only as an emergency escape (not recommended).
# PG_SSL_REJECT_UNAUTHORIZED=true

# ── Auth — REQUIRED ──────────────────────────────────────────────
# Must be at least 256-bit random hex (64 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Shared State (Valkey/Redis) — REQUIRED for production ────────
# In Coolify: add a Valkey service on the same private network
# Format: redis://valkey-service-name:6379
VALKEY_URL=redis://valkey.internal:6379
# Alternative key name (either works):
# REDIS_URL=redis://valkey.internal:6379

# ── Bunny Storage (Avatars/Images) — REQUIRED ────────────────────
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_API_KEY=your-storage-api-key
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_STORAGE_REGION=de

# ── Bunny Video (Streaming) — REQUIRED for video uploads ─────────
BUNNY_LIBRARY_ID=your-library-id
BUNNY_LIBRARY_API_KEY=your-library-api-key
BUNNY_CDN_HOSTNAME=your-cdn.b-cdn.net

# ── LiveKit (Live Streaming) — REQUIRED ──────────────────────────
LIVEKIT_URL=wss://your-livekit.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# ── Epidemic Sound (Licensed music) — optional ────────────────────
# Coolify: add on the **backend/API** service (not the static frontend build).
# Variable name must be exactly EPIDEMIC_SOUND_API_KEY — value is your key only (no quotes, no URL).
EPIDEMIC_SOUND_API_KEY=

# ── Audio fingerprint scan (copyright block on upload) — REQUIRED for music protection ─
# Set PEX_API_KEY in Coolify. Uploads with detected copyrighted audio are rejected.
PEX_API_KEY=
# PEX_API_URL=https://api.pex.com/v1
# AUDIBLE_MAGIC_API_KEY=
# Set to 0 to disable scanning even when PEX_API_KEY is set:
# AUDIO_SCAN_ENABLED=0

# ── Epidemic Sound (Licensed music) — optional ────────────────────
# Coolify: add on the **backend/API** service (not the static frontend build).
# Variable name must be exactly EPIDEMIC_SOUND_API_KEY — value is your key only (no quotes, no URL).
EPIDEMIC_SOUND_API_KEY=

# ── Audio fingerprint scan (copyright block on upload) — REQUIRED for music protection ─
# Set PEX_API_KEY in Coolify. Uploads with detected copyrighted audio are rejected.
PEX_API_KEY=
# PEX_API_URL=https://api.pex.com/v1
# AUDIBLE_MAGIC_API_KEY=
# Set to 0 to disable scanning even when PEX_API_KEY is set:
# AUDIO_SCAN_ENABLED=0

# ── Stripe (Shop physical goods ONLY) — REQUIRED ─────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Apple IAP (required for iOS in-app purchases) ─────────────────
# APPLE_ISSUER_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
# APPLE_BUNDLE_ID=com.elixstarlive.app
# APPLE_IAP_ENVIRONMENT=Production
# Shared token appended to the App Store notification URL:
# https://www.elixstarlive.co.uk/api/webhooks/apple-iap?token=<secret>
# APPLE_IAP_NOTIFICATION_SECRET=
# Apple Team ID for Universal Links AASA (also accepts APNS_TEAM_ID):
# APPLE_TEAM_ID=74Y7WAZVUV
# Sign in with Apple (native iOS). Server exposes VITE_APPLE_SIGN_IN_ENABLED via /env.js.
# APPLE_SIGN_IN_ENABLED=true
# APPLE_CLIENT_ID=com.elixstarlive.app
# Creator memberships on iOS use the same product IDs as Google
# (elix.creator.<24-hex>) but MUST be pre-created in App Store Connect
# (Apple has no runtime product-create API). When ops has created those SKUs:
# APPLE_CREATOR_MEMBERSHIP_PREPROVISIONED=true

# ── Google Play IAP (required for Android in-app purchases) ──────
# Service account JSON from Google Cloud Console (entire JSON string)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
# GOOGLE_PLAY_PACKAGE_NAME=com.elixstarlive.app
# Shared token appended to the Pub/Sub push URL:
# https://www.elixstarlive.co.uk/api/webhooks/google-play?token=<secret>
# GOOGLE_RTDN_WEBHOOK_SECRET=
#
# Creator memberships auto-create Play subscription products:
#   elix.creator.<24-hex>  + base plan "monthly"
# Play Console → Users and permissions → grant the service account
# "View app information" + "Manage store presence" (or Admin) so
# monetization.subscriptions.create / basePlans.activate succeed.
# Optional price defaults (GBP/USD/EUR monthly):
# CREATOR_MEMBERSHIP_PRICE_GBP=4.99
# CREATOR_MEMBERSHIP_PRICE_USD=4.99
# CREATOR_MEMBERSHIP_PRICE_EUR=4.99
# CREATOR_MEMBERSHIP_REGIONS=GB,US
# CREATOR_MEMBERSHIP_TITLE=Creator Membership

# ── Engagement Phase 1 + 1.5 (live defaults) ─────────────────────
# ENGAGEMENT_NEON_APPROVED=true
# ENGAGEMENT_HUB_ENABLED=true
# DAILY_LOGIN_ENABLED=true
# MISSION_REWARDS_ENABLED=true
# PROMOTIONAL_COINS_ENABLED=true
# BATTLE_ENERGY_ENABLED=true
# PROMO_GIFT_SPEND_ENABLED=true
# TREASURE_HUNT_ENABLED=true
# STICKER_COLLECTION_ENABLED=true
# CREATOR_COLLECTIONS_ENABLED=true
# Promo gifts create ZERO Diamonds. Battle Energy never affects Diamonds.
# Run: npm run migrate (Coolify release command) for engagement SQL.

# ── CORS (optional, comma-separated additional origins) ──────────
# CLIENT_URL is automatically included; add extras here:
# ALLOWED_ORIGINS=https://admin.yourdomain.com

# ── Frontend Configuration (built into client bundle) ─────────────
VITE_API_URL=https://your-domain.com
VITE_WS_URL=wss://your-domain.com
VITE_LIVEKIT_URL=wss://your-livekit.livekit.cloud
VITE_BUNNY_CDN_HOSTNAME=your-cdn.b-cdn.net
VITE_BUNNY_STORAGE_ZONE=your-storage-zone
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
VITE_APP_NAME="Elix Star Live"
VITE_CDN_URL=https://your-cdn.b-cdn.net
CLIENT_URL=https://your-domain.com

# ── Transactional email (password reset / support mail) ───────────
# Configure ONE of: SendGrid API, SMTP_URL, or SMTP_HOST (+ user/pass).
# EMAIL_FROM=noreply@elixstarlive.co.uk
# SENDGRID_API_KEY=
# SMTP_URL=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@elixstarlive.co.uk

# ── Optional ──────────────────────────────────────────────────────
# AI moderation (OpenAI) — optional, moderation will skip if not set
OPENAI_API_KEY=

# Push notifications — optional, device tokens stored but not sent without these
# Android FCM HTTP v1 (preferred):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_PROJECT_ID=
# iOS APNs token auth (.p8 key contents, not a file path):
# APNS_KEY_ID=
# APNS_TEAM_ID=74Y7WAZVUV
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# APNS_BUNDLE_ID=com.elixstarlive.app
# APNS_PRODUCTION=1
# Exactly one process should run the Valkey job consumer:
# ELIX_JOB_WORKER=1
