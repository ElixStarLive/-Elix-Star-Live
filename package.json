{
  "name": "elix-star-live",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "setup:env": "node scripts/setup-env.mjs",
    "dev": "vite",
    "dev:server": "npx tsx server/index.ts",
    "dev:all": "npx concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build --mode production",
    "build:store": "tsc -b && vite build --mode store",
    "build:android": "npm run build:store && npx cap sync android",
    "build:ios": "npm run build:store && npx cap sync ios",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc -b --noEmit",
    "test": "vitest run",
    "start": "npx tsx server/index.ts",
    "start:prod": "npx tsx server/cluster.ts",
    "cap:sync": "npm run build && npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/clipboard": "^8.0.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/preferences": "^8.0.0",
    "@capacitor/push-notifications": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capgo/native-purchases": "^8.0.24",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@mediapipe/camera_utils": "^0.3.1675466862",
    "@mediapipe/drawing_utils": "^0.3.1675466124",
    "@mediapipe/face_mesh": "^0.4.1633559619",
    "@radix-ui/react-dialog": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "framer-motion": "^12.29.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "livekit-client": "^2.17.2",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.511.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intersection-observer": "^10.0.2",
    "react-router-dom": "^7.13.0",
    "stripe": "^20.3.0",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "yauzl": ">=3.2.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@eslint/js": "^9.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "babel-plugin-react-dev-locator": "^1.0.6",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "terser": "^5.46.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.5"
  }
}
